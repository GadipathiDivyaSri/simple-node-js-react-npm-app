pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        CI = 'true'
    }

    stages {
        stage('Build') {
            steps {
                sh 'rm -rf node_modules package-lock.json'
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Deliver') {
            steps {
                echo 'Pipeline completed successfully'
            }
        }
    }
}
